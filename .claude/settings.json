{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Astrolabe instance — personal KB + four-system destiny advisory. Destiny canon (.claude/canon/) is hook-protected: canon-guard.js (PreToolUse Edit/Write/NotebookEdit + Bash) + permissions.deny block silent mutation; inject-canon.js (UserPromptSubmit) injects the protected guardrails every turn. Amend canon only via the rules/canon-protection.md ceremony (CANON_AMEND=1).",
  "permissions": {
    "deny": [
      "Edit(.claude/canon/**)",
      "Write(.claude/canon/**)",
      "NotebookEdit(.claude/canon/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-canon.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/calc-reminder.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/canon-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/canon-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/vet-gate.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
